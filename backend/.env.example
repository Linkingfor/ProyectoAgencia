# ═══════════════════════════════════════════════════════════
#  BACKEND — Variables de entorno
#  Copia este archivo como  .env  y completa los valores.
#  En Render se configuran en: Service → Environment.
# ═══════════════════════════════════════════════════════════

# Puerto (Render lo asigna solo; en local usa 3001)
PORT=3001

# development | production   (Render debe ir en production)
NODE_ENV=development

# ─── Base de datos PostgreSQL ────────────────────────────────
# Cadena de conexión completa.
#   Local:   postgresql://postgres:TU_CLAVE@127.0.0.1:5432/agenciaviajes_db
#   Render:  la copias de tu base de datos de Render (Internal Database URL)
DATABASE_URL=postgresql://postgres:1234@127.0.0.1:5432/agenciaviajes_db

# ─── Seguridad JWT ───────────────────────────────────────────
# Cadena larga y aleatoria. En Render puedes generarla automáticamente.
JWT_SECRET=pon-aqui-una-clave-larga-y-aleatoria
JWT_EXPIRES_IN=8h

# ─── Stripe (claves de prueba) ───────────────────────────────
# La clave secreta empieza con  sk_test_  (la copias de tu panel de Stripe).
STRIPE_SECRET_KEY=coloca-aqui-tu-clave-secreta-de-stripe
STRIPE_CURRENCY=pen

# ─── Correo (Gmail) para envío de boletas ────────────────────
# EMAIL_APP_PASSWORD = contraseña de aplicación de 16 letras (SIN espacios)
# Se genera en: https://myaccount.google.com/apppasswords
EMAIL_USER=tucorreo@gmail.com
EMAIL_APP_PASSWORD=coloca-aqui-tu-contrasena-de-aplicacion
EMAIL_FROM_NAME=Agencia de Viajes Ica

# ─── CORS ────────────────────────────────────────────────────
# URLs del frontend permitidas, separadas por coma (sin barra final).
# Ej: https://agenciaviajes-frontend.onrender.com
CORS_ORIGINS=https://proyectoagencia.netlify.app/
