# ═══════════════════════════════════════════════════════════
#  FRONTEND — Variables de entorno (Vite)
#  Copia este archivo como  .env  y completa los valores.
#  En Render (Static Site) se configuran en: Environment.
#  OJO: en Vite las variables DEBEN empezar con VITE_
# ═══════════════════════════════════════════════════════════

# URL del backend + /api
#   Local:   http://localhost:3001/api
#   Render:  https://TU-BACKEND.onrender.com/api
VITE_API_URL=http://localhost:3001/api

# Clave PÚBLICA de Stripe (empieza con pk_test_). Es pública, no es secreta.
VITE_STRIPE_PUBLISHABLE_KEY=coloca-aqui-tu-clave-publica-de-stripe
